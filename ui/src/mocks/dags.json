  {
    "name": "csv-flow",
    "active": true,
    "owner": "alice",
    "allowedRoles": ["engines", "ops"],
    "description": "File-type routing: ingest a document and archive by format.",
    "updatedAt": "2026-07-10T14:22:00Z",
    "nodes": [
      {
        "name": "ingest",
        "topic": "ingest",
        "host": "localhost",
        "port": 8001,
        "entry": true,
        "routes": [
          { "when": { "field": "message", "op": "contains", "value": "[CSV]" }, "to": "csv" },
          { "when": { "field": "message", "op": "contains", "value": "[PDF]" }, "to": "pdf" }
        ]
      },
      {
        "name": "csv",
        "topic": "csv",
        "host": "localhost",
        "port": 8002,
        "tools": ["parse_csv"],
        "routes": [{ "to": "archive" }]
      },
      {
        "name": "pdf",
        "topic": "pdf",
        "host": "localhost",
        "port": 8003,
        "routes": [{ "to": "archive" }]
      },
      {
        "name": "archive",
        "topic": "archive",
        "host": "localhost",
        "port": 8004,
        "routes": []
      }
    ]
  },
